# --- verophi (System Under Test) ---

# Docker image for verophi. Default: ghcr.io/verophi/verophi:latest
# For local dev: docker build -t verophi:dev . && VEROPHI_IMAGE=verophi:dev make test-github
# VEROPHI_IMAGE=ghcr.io/verophi/verophi:latest

# GitHub token for the verophi E2E tests (read-only; a public repo needs no scopes)
# VEROPHI_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitLab token for the verophi E2E tests (read_api scope)
# VEROPHI_GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# Optional GitLab URL override (default: https://gitlab.com)
# VEROPHI_GITLAB_URL=https://gitlab.com

# --- Renovate (GitHub): GitHub App auth ---
# Used only by `make renovate-github` (Layer 3). Provide the app id, the
# installation id, and the private key.

RENOVATE_GITHUB_APP_ID=000000
RENOVATE_GITHUB_APP_INSTALLATION_ID=00000000
# Path to the app private key (.pem, gitignored). In CI set RENOVATE_GITHUB_APP_KEY
# with the key content instead of the file path.
RENOVATE_GITHUB_APP_KEY_FILE=app-private-key.pem
# RENOVATE_GITHUB_APP_KEY=<full PEM content, used in CI>

# GitHub fixture repo (default: verophi/test-fixtures)
# RENOVATE_GITHUB_TEST_FIXTURE_REPO=verophi/test-fixtures

# --- Renovate (GitLab): token auth ---
# Used by `make renovate-gitlab` (Layer 3). Token with api scope.

RENOVATE_GITLAB_TOKEN=glpat-xxxxxxxxxxxxxxxxxxxx

# GitHub token for registry/datasource lookups when running against GitLab
# (github-tags datasource, Go modules, etc.)
# RENOVATE_GITHUB_COM_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitLab fixture repo (default: verophi/test-fixtures)
# RENOVATE_GITLAB_TEST_FIXTURE_REPO=verophi/test-fixtures

# GitLab base URL (default: https://gitlab.com)
# RENOVATE_GITLAB_URL=https://gitlab.com

# --- Config ---

# Pinned Renovate image version
# RENOVATE_IMAGE=renovate/renovate:43.249.0

# Path to the test-fixtures checkout (default: ../test-fixtures)
# FIXTURES_REPO_PATH=../test-fixtures
